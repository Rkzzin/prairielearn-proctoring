# =============================================================================
#  proctor-station — configuração
#  Copie este arquivo para .env e preencha os valores.
#
#    cp .env.example .env
#
#  Variáveis de ambiente têm prioridade sobre o .env.
#  Nunca versione o .env (já está no .gitignore).
# =============================================================================


# -----------------------------------------------------------------------------
#  AWS — credenciais e região
#  Alternativa: configure via ~/.aws/credentials ou IAM role na NUC
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1


# -----------------------------------------------------------------------------
#  S3 — bucket e prefixos
# -----------------------------------------------------------------------------

# Nome do bucket S3
PROCTOR_S3_BUCKET=proctor-station

# Região do bucket (deve coincidir com AWS_DEFAULT_REGION)
PROCTOR_S3_REGION=us-east-1

# Prefixo onde ficam as fotos de cadastro dos alunos
# Estrutura: s3://{bucket}/{PHOTOS_PREFIX}/{turma_id}/{nome_aluno}.png
PROCTOR_S3_PHOTOS_PREFIX=fotos

# Prefixo onde ficam as gravações de prova
PROCTOR_S3_RECORDINGS_PREFIX=gravacoes

# Duração de cada segmento de gravação (segundos)
PROCTOR_S3_SEGMENT_DURATION_SEC=300


# -----------------------------------------------------------------------------
#  Face — modelos dlib e parâmetros de reconhecimento
# -----------------------------------------------------------------------------

# Diretório com os arquivos .dat do dlib (baixados por download_models.sh)
PROCTOR_FACE_MODELS_DIR=models

# Diretório local onde os .pkl de encodings são salvos
PROCTOR_FACE_ENCODINGS_DIR=data/encodings

# Distância euclidiana máxima para considerar match
# Menor = mais restritivo. Valores típicos: 0.4 (estrito) a 0.6 (permissivo)
PROCTOR_FACE_MATCH_THRESHOLD=0.45

# Usar detector CNN (requer GPU) em vez de HOG (CPU)
# true apenas se a NUC tiver GPU compatível com dlib/CUDA
PROCTOR_FACE_USE_CNN_DETECTOR=false

# Máximo de tentativas de identificação antes de pedir intervenção manual
PROCTOR_FACE_MAX_IDENTIFICATION_ATTEMPTS=3

# Índice da câmera USB (/dev/videoN)
PROCTOR_FACE_CAMERA_INDEX=0
PROCTOR_FACE_CAMERA_WIDTH=1280
PROCTOR_FACE_CAMERA_HEIGHT=720
PROCTOR_FACE_CAMERA_FPS=30

# Fator de escala do frame antes da detecção (performance)
# 0.5 = processar em metade da resolução (recomendado para CPU)
PROCTOR_FACE_DETECTION_SCALE=0.5

# Jitters por encoding durante identificação
# Use 1 para velocidade, 3-5 para maior precisão
PROCTOR_FACE_NUM_JITTERS=1


# -----------------------------------------------------------------------------
#  Proctoring engine — limiares de comportamento
# -----------------------------------------------------------------------------

# Desvio horizontal do olhar para acionar alerta (0.0 a 1.0)
PROCTOR_GAZE_H_THRESHOLD=0.35

# Desvio vertical do olhar para acionar alerta (0.0 a 1.0)
PROCTOR_GAZE_V_THRESHOLD=0.30

# Segundos com olhar desviado antes de registrar evento
PROCTOR_GAZE_DURATION_SEC=3.0

# Segundos sem rosto detectado antes de registrar ausência
PROCTOR_ABSENCE_TIMEOUT_SEC=5.0

# Bloquear sessão ao detectar múltiplos rostos
PROCTOR_MULTI_FACE_BLOCK=true


# -----------------------------------------------------------------------------
#  App — configurações gerais
# -----------------------------------------------------------------------------

# Porta da API REST
PROCTOR_APP_API_PORT=8000

# Nível de log: DEBUG | INFO | WARNING | ERROR
PROCTOR_APP_LOG_LEVEL=INFO

# Diretório de dados locais (logs, temporários)
PROCTOR_APP_DATA_DIR=/opt/proctor/data
